@page "/edit/{id:guid}"
@using BlazorApp.Client.Components
@using BlazorApp.Client.Services
@using BlazorApp.Shared
@using Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.FluentUI.AspNetCore.Components.Icons.Regular

@inject NavigationManager Navigation
@inject Blazored.LocalStorage.ILocalStorageService localStorage
@inject ISyncEventService syncEventService

<PageTitle>Edit Item</PageTitle>

<EditForm Model="Item" OnValidSubmit="Save">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="edit-section">
        <div class="form-field">
            <label class="form-label">Name</label>
            <InputText @bind-Value="Item.Name" class="form-control form-control-sm" />
        </div>

        <div class="form-field">
            <label class="form-label">Default Stock Usage</label>
            <InputNumber @bind-Value="Item.DefaultStockUsage" class="form-control form-control-sm narrow-input" />
        </div>
    </div>

    @if (Item.PastOccurrences.Any())
    {
        <h5 class="section-heading">Past Occurrences</h5>

        <div class="table-responsive">
            <table class="table table-sm table-hover">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Time</th>
                        <th class="col-narrow">Stock Used</th>
                        <th class="col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var occurrence in Item.PastOccurrences.OrderByDescending(a => a.ActualTimestamp).Take(showHistoryCount))
                    {
                        <tr>
                            <td>
                                <FluentDatePicker Value="@occurrence.ActualTimestamp.ToLocalTime()" ValueChanged="@(e => occurrence.ActualTimestamp = e.GetValueOrDefault().ToUniversalTime())" />
                            </td>
                            <td>
                                <FluentTimePicker Value="@occurrence.ActualTimestamp.ToLocalTime()" ValueChanged="@(e => occurrence.ActualTimestamp = e.GetValueOrDefault().ToUniversalTime())" />
                            </td>
                            <td class="col-narrow">
                                <InputNumber @bind-Value="occurrence.StockUsed" class="form-control form-control-sm narrow-input" />
                            </td>
                            <td class="col-actions">
                                <FluentIcon Value="@(new Size20.Delete())" OnClick="() => Item.PastOccurrences.Remove(occurrence)" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="() => showHistoryCount += 5">Show More</button>
    }

    <h5 class="section-heading">
        Limits
        <FluentIcon Id="limitTooltip" Icon="Size20.Info" />
    </h5>
    <p class="section-hint">Define the maximum amount allowed within a time window.</p>

    <FluentTooltip Anchor="limitTooltip">
        <strong>For example</strong>
        <p>if you are tracking Paracetamol then you want to add 2 limits:</p>
        <ul>
            <li>1 every 4 hours</li>
            <li>4 every 24 hours</li>
        </ul>
    </FluentTooltip>

    @foreach (var target in Item.Targets)
    {
        <div class="target-row">
            <TargetEditor Target="target" />
            <FluentIcon Value="@(new Size20.Delete())" OnClick="() => Item.Targets.Remove(target)" />
        </div>
    }

    <button type="button" class="btn btn-outline-primary btn-sm" @onclick="() => Item.Targets.Add(new Target())">+ Add Limit</button>

    <h5 class="section-heading">Stock Acquisitions</h5>
    @if (Item.StockAcquisitions.Any())
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover">
                <thead>
                    <tr>
                        <th>Date Acquired</th>
                        <th class="col-narrow">Qty</th>
                        <th>Note</th>
                        <th class="col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var acquisition in Item.StockAcquisitions)
                    {
                        <tr>
                            <td>
                                <FluentDatePicker Value="@acquisition.DateAcquired.ToLocalTime()" ValueChanged="@(e => acquisition.DateAcquired = e.GetValueOrDefault().ToUniversalTime())" />
                            </td>
                            <td class="col-narrow">
                                <InputNumber @bind-Value="acquisition.Quantity" class="form-control form-control-sm narrow-input" />
                            </td>
                            <td>
                                <InputText @bind-Value="acquisition.Note" class="form-control form-control-sm" />
                            </td>
                            <td class="col-actions">
                                <FluentIcon Value="@(new Size20.Delete())" OnClick="() => Item.StockAcquisitions.Remove(acquisition)" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted section-hint">No stock acquisitions recorded yet.</p>
    }

    <button type="button" class="btn btn-outline-primary btn-sm" @onclick="() => Item.StockAcquisitions.Add(new StockAcquisition { DateAcquired = DateTime.UtcNow })">+ Add Stock Acquisition</button>

    <div class="form-actions">
        @if (!_isNewItem)
        {
            <button type="button" @onclick="ViewStats" class="btn btn-outline-primary">View Stats</button>
        }
        <button type="submit" class="btn btn-success">Save</button>
        <button type="button" @onclick="Cancel" class="btn btn-secondary">Cancel</button>
        <button type="button" @onclick="Delete" class="btn btn-danger">Delete</button>
    </div>
</EditForm>

@code {
    [Parameter]
    public Guid Id { get; set; }

    [SupplyParameterFromForm]
    public TrackedItem Item { get; set; } = new TrackedItem(); //Needs to be "new" otherwise the form complains as it loads before the data is loaded

    private int showHistoryCount = 5;
    private bool _isNewItem;

    protected override async Task OnInitializedAsync()
    {
        var loadedItem = await localStorage.GetItemAsync<TrackedItem>(nameof(TrackedItem) + Id);

        if (loadedItem != null)
        {
            Item = loadedItem;
        }
        else
        {
            Item.Id = Id;
            _isNewItem = true;
        }
    }

    async void Save()
    {
        //Reset all safety times in case the Targets have changed
        var occurrences = Item.PastOccurrences;
        Item.PastOccurrences = new List<Occurrence>();

        foreach (var occurrence in occurrences)
        {
            Item.AddOccurrence(occurrence.ActualTimestamp, occurrence.StockUsed);
        }

        await localStorage.SetItemAsync(nameof(TrackedItem) + Item.Id, Item);

        var payload = System.Text.Json.JsonSerializer.Serialize(Item, SerializationContext.Default.TrackedItem);
        await syncEventService.EnqueueAsync(new SyncEvent
        {
            EventType = _isNewItem ? SyncEventType.Created : SyncEventType.Updated,
            ItemId = Item.Id,
            Payload = payload
        });
        _isNewItem = false;

        Navigation.NavigateTo("/");
    }

    void Cancel()
    {
        Navigation.NavigateTo("/");
    }

    void ViewStats()
    {
        Navigation.NavigateTo("/stats/" + Item.Id);
    }

    async void Delete()
    {
        await localStorage.RemoveItemAsync(nameof(TrackedItem) + Item.Id);
        await syncEventService.EnqueueAsync(new SyncEvent
        {
            EventType = SyncEventType.Deleted,
            ItemId = Item.Id
        });
        Navigation.NavigateTo("/");
    }
}

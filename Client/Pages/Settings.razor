@page "/settings"
@using BlazorApp.Shared
@using BlazorApp.Client.Services
@using System.Reflection

@inject NavigationManager Navigation
@inject IBrowserIdentityService identityService
@inject IAppSettingsService AppSettingsService
@inject PwaUpdateService PwaUpdateService
@implements IDisposable

<PageTitle>Settings</PageTitle>

<h1>Settings</h1>

<p>Manage your application settings and data import/export options.</p>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Data Management</h5>
            </div>
            <div class="card-body">
                <p>Export downloads a <code>tracker.json</code> backup of your tracked items and browser identity to this device.</p>
                <p class="text-muted">
                    Use <strong>Export</strong> to save a copy before clearing browser data or moving devices, then use <strong>Import Data</strong> to load that exported file back into the app later.
                </p>
                <div class="d-flex gap-2">
                    <BlazorApp.Client.Components.Export />
                    <a href="/import" class="btn btn-success">Import Data</a>
                </div>

                <div class="mt-4 pt-3 border-top">
                    <h6>Experimental Cloudflare/API posting</h6>
                    <div class="form-check form-switch">
                        <input class="form-check-input"
                               type="checkbox"
                               id="experimentalApiPosting"
                               checked="@experimentalApiPostingEnabled"
                               @onchange="OnExperimentalApiPostingChanged" />
                        <label class="form-check-label" for="experimentalApiPosting">
                            Enable Cloudflare/API posting
                        </label>
                    </div>
                    <p class="text-muted mb-0">
                        <small>
                            This is experimental and is off by default. When disabled, the app keeps data on this device and will not queue or send Cloudflare/API sync requests.
                        </small>
                    </p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Browser Identity</h5>
            </div>
            <div class="card-body">
                @if (identity != null)
                {
                    <p>Your local browser identity has been created for this offline application.</p>
                    <dl class="row">
                        <dt class="col-sm-4">Identity ID:</dt>
                        <dd class="col-sm-8"><code class="small">@identity.Id</code></dd>
                        
                        <dt class="col-sm-4">Created:</dt>
                        <dd class="col-sm-8">@identity.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss UTC")</dd>
                        
                        <dt class="col-sm-4">Algorithm:</dt>
                        <dd class="col-sm-8">@identity.Algorithm (@identity.Curve)</dd>
                        
                        <dt class="col-sm-4">Public Key:</dt>
                        <dd class="col-sm-8">
                            <div class="text-truncate" style="max-width: 200px;" title="@identity.PublicKey">
                                <code class="small">@identity.PublicKey</code>
                            </div>
                        </dd>
                    </dl>
                    <small class="text-muted">This identity is included in your data exports and stored locally in your browser.</small>
                }
                else
                {
                    <p class="text-muted">Loading identity...</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <div class="card">
        <div class="card-header">
            <h5>About</h5>
        </div>
        <div class="card-body">
            <dl class="row mb-3">
                <dt class="col-sm-4">Version:</dt>
                <dd class="col-sm-8"><code>@appVersion</code></dd>
            </dl>
            @if (updateAvailable)
            {
                <div class="alert alert-info d-flex align-items-center gap-2 mb-3" role="alert">
                    <span>🔄</span>
                    <span>A new version is available!</span>
                    <button type="button" class="btn btn-primary btn-sm ms-auto" @onclick="ReloadApp">Reload to update</button>
                </div>
            }
            else
            {
                <p class="text-muted mb-3">@updateStatusMessage</p>
            }
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CheckForUpdates" disabled="@isCheckingForUpdates">
                @if (isCheckingForUpdates)
                {
                    <span>Checking...</span>
                }
                else
                {
                    <span>Check for Updates</span>
                }
            </button>
        </div>
    </div>
</div>

<div class="mt-4">
    <a href="/" class="btn btn-secondary">
        <span class="bi bi-arrow-left" aria-hidden="true"></span> Back to Home
    </a>
</div>

@code {
    private const int UpdateCheckDelayMs = 3000;

    private BrowserIdentity? identity;
    private bool experimentalApiPostingEnabled;
    private string appVersion = string.Empty;
    private bool updateAvailable = false;
    private bool isCheckingForUpdates = false;
    private string updateStatusMessage = "You're up to date.";

    protected override async Task OnInitializedAsync()
    {
        identity = await identityService.GetOrCreateIdentityAsync();
        experimentalApiPostingEnabled = await AppSettingsService.GetExperimentalCloudflareApiPostingEnabledAsync();

        appVersion = typeof(Program).Assembly
            .GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion ?? "Unknown";

        PwaUpdateService.UpdateAvailable += OnUpdateAvailable;
        updateAvailable = PwaUpdateService.IsUpdateAvailable;
        if (updateAvailable)
        {
            updateStatusMessage = "A new version is available!";
        }
    }

    private void OnUpdateAvailable()
    {
        updateAvailable = true;
        isCheckingForUpdates = false;
        updateStatusMessage = "A new version is available!";
        InvokeAsync(StateHasChanged);
    }

    private async Task CheckForUpdates()
    {
        isCheckingForUpdates = true;
        updateStatusMessage = "Checking for updates...";
        await PwaUpdateService.CheckForUpdatesAsync();
        await Task.Delay(UpdateCheckDelayMs);
        if (!updateAvailable)
        {
            updateStatusMessage = "You're up to date.";
        }
        isCheckingForUpdates = false;
    }

    private async Task ReloadApp()
    {
        await PwaUpdateService.ReloadApplicationAsync();
    }

    private async Task OnExperimentalApiPostingChanged(ChangeEventArgs e)
    {
        experimentalApiPostingEnabled = e.Value is bool enabled && enabled;
        await AppSettingsService.SetExperimentalCloudflareApiPostingEnabledAsync(experimentalApiPostingEnabled);
    }

    public void Dispose()
    {
        PwaUpdateService.UpdateAvailable -= OnUpdateAvailable;
    }
}

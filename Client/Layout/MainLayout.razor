@using Microsoft.FluentUI.AspNetCore.Components
@inject BlazorApp.Client.Services.PwaUpdateService PwaUpdateService
@inject BlazorApp.Client.Services.PeriodicSyncService PeriodicSyncService

@inherits LayoutComponentBase
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <article class="content px-3 px-md-4">
            @Body
        </article>
    </main>

    <FluentToastProvider MaxToastCount="10" />
    <FluentTooltipProvider />
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await PwaUpdateService.InitializeAsync();
            await PeriodicSyncService.InitializeAsync();
        }
    }
}